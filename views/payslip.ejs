<%# ── payslip.ejs ────────────────────────────────────────────────────────────
    Rendered as a fragment and injected via fetch() into a modal's innerHTML.
    No <html>/<head>/<body> tags — just the content.
    The document layout (header, table, numbers) must stay pixel-perfect.
    Only the action bar gets the Tailwind treatment.
%>

<!-- Scoped styles for the payslip document fragment -->
<style>
  .ps-doc * { box-sizing: border-box; }
  .ps-doc { font-family: Arial, sans-serif; }
  .ps-doc .payslip-container {
    width: 100%; max-width: 720px; margin: 0 auto;
    padding: 20px 35px; background: #fff; position: relative;
    border-radius:6px;
  }
  .ps-doc .office-title { color:#1a4d80; font-weight:bold; font-size:12px; display:block; }
  .ps-doc .payroll-table { width:100%; border-collapse:collapse; border:1.5px solid #000; margin-top:10px; font-size:11px; }
  .ps-doc .payroll-table th, .ps-doc .payroll-table td { border:1px solid #000; padding:2px 8px; line-height:1.2; }
  .ps-doc .bg-blue { background-color:#c0ecf8 !important; font-weight:bold; text-align:center; }
  .ps-doc .text-right { text-align:right; font-family:'Courier New',Courier,monospace; font-weight:bold; }
</style>

<div style="text-align:right; padding:8px 12px 8px 12px; font-family:Arial,sans-serif;">
  <a href="/payslip/<%= employee.id %>/print" target="_blank"
    style="display:inline-flex;align-items:center;gap:5px;padding:5px 12px;border-radius:6px;
           font-size:11px;font-weight:600;background:#1a5276;color:#fff;
           text-decoration:none;border:none;cursor:pointer;letter-spacing:0.3px;">
    <svg style="width:12px;height:12px;flex-shrink:0;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
        d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z"/>
    </svg>
    Print
  </a>
</div>

<div class="ps-doc">
  <div class="payslip-container">
    <img src="/images/uhi.png" alt="" style="position:absolute;top:0;left:0;width:220px;height:auto;opacity:0.4;pointer-events:none;z-index:0;">

    <div style="display:flex;align-items:center;margin-bottom:10px;position:relative;z-index:1;">
      <img src="/images/bp.png"     alt="Bagong Pilipinas" style="height:48px;margin-right:10px;">
      <img src="/images/dabfar.png" alt="BFAR"             style="height:48px;margin-right:12px;">
      <div style="font-size:10px;line-height:1.2;font-family:Arial,sans-serif;">
        Republic of the Philippines | Department of Agriculture<br>
        <strong>BUREAU OF FISHERIES AND AQUATIC RESOURCES</strong><br>
        <span class="office-title">REGIONAL FISHERIES OFFICE - MIMAROPA</span>
        Sapul, Calapan City 5200, Oriental Mindoro<br>
        <span style="color:blue;text-decoration:underline;">ord.mimaropa@bfar.da.gov.ph | records.mimaropa@bfar.da.gov.ph</span>
      </div>
    </div>

    <div style="text-align:center;margin-bottom:10px;">
      <h2 style="margin:0;font-size:16px;letter-spacing:1px;line-height:1;font-family:Arial,sans-serif;">PAY SLIP</h2>
      <strong style="text-transform:uppercase;font-size:12px;font-family:Arial,sans-serif;">
        <%= month %> - <%= cutoff === 'FIRST_HALF' ? '1st Half' : (cutoff === 'SECOND_HALF' ? '2nd Half' : cutoff) %>
      </strong>
    </div>

    <div style="margin-bottom:8px;font-size:12px;font-family:Arial,sans-serif;">
      <strong>Name: <%= employee.name.toUpperCase() %></strong><br>
      <strong>Account No.: <%= employee.account_no %></strong>
    </div>

    <table class="payroll-table">
      <thead>
        <tr class="bg-blue">
          <th style="width:28%;">EARNINGS</th>
          <th style="width:22%;">Amount</th>
          <th style="width:32%;">DEDUCTIONS</th>
          <th style="width:18%;">Amount</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td>Basic Pay</td>
          <td class="text-right"><%= Number(employee.basic_pay||0).toLocaleString(undefined,{minimumFractionDigits:2}) %></td>
          <td>LATE/ABSENCES</td>
          <td class="text-right"><%= Number(employee.late_absences||0).toFixed(2) %></td>
        </tr>
        <tr>
          <td rowspan="8" style="border-bottom:1px solid #000;"></td>
          <td rowspan="8" style="border-bottom:1px solid #000;"></td>
          <td>PAG-IBIG (MP1)</td>
          <td class="text-right"><%= Number(employee.pagibig_mp1||0).toFixed(2) %></td>
        </tr>
        <tr><td>PAG-IBIG (MP2)</td><td class="text-right"><%= Number(employee.pagibig_mp2||0).toFixed(2) %></td></tr>
        <tr><td>PAG-IBIG (MPL)</td><td class="text-right"><%= Number(employee.pagibig_mpl||0).toFixed(2) %></td></tr>
        <tr><td>PAG-IBIG (Calamity)</td><td class="text-right"><%= Number(employee.pagibig_calamity||0).toFixed(2) %></td></tr>
        <tr><td>SSS</td><td class="text-right"><%= Number(employee.sss||0).toFixed(2) %></td></tr>
        <tr><td>PHILHEALTH</td><td class="text-right"><%= Number(employee.philhealth||0).toFixed(2) %></td></tr>
        <tr><td>TAX</td><td class="text-right"><%= Number(employee.tax||0).toFixed(2) %></td></tr>
        <tr><td>DISALLOWANCES</td><td class="text-right"><%= Number(employee.disallowances||0).toFixed(2) %></td></tr>
        <tr style="font-weight:bold;background:#fafafa;">
          <td>Total Earnings</td>
          <td class="text-right"><%= Number(employee.basic_pay||0).toLocaleString(undefined,{minimumFractionDigits:2}) %></td>
          <td style="text-align:right;">Total Deductions</td>
          <td class="text-right"><%= Number(totalDeductions||0).toLocaleString(undefined,{minimumFractionDigits:2}) %></td>
        </tr>
        <tr>
          <td colspan="2" style="border:none;"></td>
          <td class="bg-blue" style="text-align:right;border:1px solid #000;">Net Pay</td>
          <td class="bg-blue" style="border:1px solid #000;text-align:right;font-family:monospace;font-size:13px;font-weight:bold;">
            <%= Number(netPay||0).toLocaleString(undefined,{minimumFractionDigits:2}) %>
          </td>
        </tr>
      </tbody>
    </table>

    <div style="margin-top:8px;text-align:right;font-style:italic;font-size:10px;font-family:Arial,sans-serif;">
      Prepared by: HRMU
    </div>
  </div>
</div>
