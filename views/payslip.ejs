<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>View Payslip - <%= employee.name %></title>
    <style>
        * { box-sizing: border-box; }
        
       

        .payslip-container {
            width: 100%;
            max-width: 750px; /* Slightly narrower to fit better */
            margin: 0 auto;
            padding: 15px 35px; /* Tightened vertical padding */
            background-color: white;
            position: relative;
            box-shadow: 0 4px 10px rgba(0,0,0,0.1);
        }

        .office-title {
            color: #1a4d80;
            font-weight: bold;
            font-size: 12px; /* Shrunk */
            display: block;
        }

        .payroll-table {
            width: 100%;
            border-collapse: collapse;
            border: 1.5px solid #000;
            margin-top: 10px; /* Shrunk */
            font-size: 11px; /* Shrunk for compactness */
        }

        .payroll-table th, .payroll-table td {
            border: 1px solid #000;
            padding: 2px 8px; /* Very tight cell padding */
            line-height: 1.2;
        }

        .bg-blue {
            background-color: #c0ecf8 !important;
            font-weight: bold;
            text-align: center;
        }

        .text-right { 
            text-align: right; 
            font-family: 'Courier New', Courier, monospace; 
            font-weight: bold; 
        }

        .btn-header-container {
            width: 100%;
            max-width: 750px;
            display: flex;
            justify-content: space-between;
            margin-bottom: 5px;
        }

        .btn-action {
            padding: 5px 12px;
            background-color: #6c757d;
            color: white;
            text-decoration: none;
            border-radius: 4px;
            font-weight: bold;
            font-size: 11px;
        }
    </style>
</head>


    <div class="btn-header-container">
    <a href="/payslip/<%= employee.id %>/print" target="_blank"><button>Print</button></a>

    </div>

    <div class="payslip-container">
        <img src="/images/uhi.png" alt="" style="position: absolute; top: 0; left: 0; width: 250px; height: auto; opacity: 0.4; pointer-events: none;">

        <div style="display: flex; align-items: center; margin-bottom: 10px; position: relative; z-index: 1;">
            <img src="/images/bp.png" alt="Bagong Pilipinas" style="height: 50px; margin-right: 12px;">
            <img src="/images/dabfar.png" alt="BFAR" style="height: 50px; margin-right: 15px;">
            
            <div style="font-size: 10px; line-height: 1.1;">
                Republic of the Philippines | Department of Agriculture<br>
                <strong>BUREAU OF FISHERIES AND AQUATIC RESOURCES</strong><br>
                <span class="office-title">REGIONAL FISHERIES OFFICE - MIMAROPA</span>
                Sapul, Calapan City 5200, Oriental Mindoro<br>
                <span style="color: blue; text-decoration: underline;">ord.mimaropa@bfar.da.gov.ph | records.mimaropa@bfar.da.gov.ph</span>
            </div>
        </div>

        <div style="text-align: center; margin-bottom: 10px;">
            <h2 style="margin: 0; font-size: 16px; letter-spacing: 1px; line-height: 1;">PAY SLIP</h2>
            <strong style="text-transform: uppercase; font-size: 12px;">
                <%= month %> - <%= cutoff === 'FIRST_HALF' ? '1st Half' : (cutoff === 'SECOND_HALF' ? '2nd Half' : cutoff) %>
            </strong>
        </div>

        <div style="margin-bottom: 8px; font-size: 12px;">
            <strong>Name: <%= employee.name.toUpperCase() %></strong> <br>
            <strong>Account No.: <%= employee.account_no %></strong>
        </div>

        <table class="payroll-table">
            <thead>
                <tr class="bg-blue">
                    <th style="width: 28%;">EARNINGS</th>
                    <th style="width: 22%;">Amount</th>
                    <th style="width: 32%;">DEDUCTIONS</th>
                    <th style="width: 18%;">Amount</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td style="text-align:left;">Basic Pay</td>
                    <td class="text-right"><%= Number(employee.basic_pay || 0).toLocaleString(undefined, {minimumFractionDigits: 2}) %></td>
                    <td style="text-align:left;">LATE/ABSENCES</td>
                    <td class="text-right"><%= Number(employee.late_absences || 0).toFixed(2) %></td>
                </tr>
                <tr>
                    <td rowspan="8" style="border-bottom: 1px solid #000;"></td>
                    <td rowspan="8" style="border-bottom: 1px solid #000;"></td>
                    <td style="text-align:left;">PAG-IBIG (MP1)</td>
                    <td class="text-right"><%= Number(employee.pagibig_mp1 || 0).toFixed(2) %></td>
                </tr>
                <tr>
                    <td style="text-align:left;">PAG-IBIG (MP2)</td>
                    <td class="text-right"><%= Number(employee.pagibig_mp2 || 0).toFixed(2) %></td>
                </tr>
                <tr>
                    <td style="text-align:left;">PAG-IBIG (MPL)</td>
                    <td class="text-right"><%= Number(employee.pagibig_mpl || 0).toFixed(2) %></td>
                </tr>
                <tr>
                    <td style="text-align:left;">PAG-IBIG (Calamity)</td>
                    <td class="text-right"><%= Number(employee.pagibig_calamity || 0).toFixed(2) %></td>
                </tr>
                <tr>
                    <td style="text-align:left;">SSS</td>
                    <td class="text-right"><%= Number(employee.sss || 0).toFixed(2) %></td>
                </tr>
                <tr>
                    <td style="text-align:left;">PHILHEALTH</td>
                    <td class="text-right"><%= Number(employee.philhealth || 0).toFixed(2) %></td>
                </tr>
                <tr>
                    <td style="text-align:left;">TAX</td>
                    <td class="text-right"><%= Number(employee.tax || 0).toFixed(2) %></td>
                </tr>
                <tr>
                    <td style="text-align:left;">DISALLOWANCES</td>
                    <td class="text-right"><%= Number(employee.disallowances || 0).toFixed(2) %></td>
                </tr>
                <tr style="font-weight: bold; background: #fafafa;">
                    <td>Total Earnings</td>
                    <td class="text-right"><%= Number(employee.basic_pay || 0).toLocaleString(undefined, {minimumFractionDigits: 2}) %></td>
                    <td style="text-align: right;">Total Deductions</td>
                    <td class="text-right"><%= Number(totalDeductions || 0).toLocaleString(undefined, {minimumFractionDigits: 2}) %></td>
                </tr>
                <tr>
                    <td colspan="2" style="border: none;"></td>
                    <td class="bg-blue" style="text-align: right; border: 1px solid #000;">Net Pay</td>
                    <td class="bg-blue" style="border: 1px solid #000; text-align: right; font-family: monospace; font-size: 13px;">
                        <%= Number(netPay || 0).toLocaleString(undefined, {minimumFractionDigits: 2}) %>
                    </td>
                </tr>
            </tbody>
        </table>

        <div style="margin-top: 8px; text-align: right; font-style: italic; font-size: 10px;">
            Prepared by: HRMU
        </div>
    </div>
