<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Payslip - <%= payslip.employee_name %></title>
    <style>
        @media print {
            .no-print {
                display: none !important;
            }
        }
    </style>
</head>
<body>
  
    <div style="width: 800px; margin: 0 auto; font-family: Arial, sans-serif; padding: 40px; background-color: white; position: relative;">
  
      <img src="<%= images?.headerGraphic || '/images/uhi.png' %>" alt="Header Graphic" style="position: absolute; top: 0; left: 0; width: 350px; height: auto; opacity: 0.9;">

      <div style="display: flex; align-items: center; justify-content: flex-start; margin-bottom: 20px; position: relative; z-index: 1;">
        <img src="<%= images?.lho || '/images/bp.png'%>" alt="Bagong Pilipinas" style="height: 65px; margin-right: 15px;">
        
        <img src="<%= images?.bfar || '/images/dabfar.png'%>" alt="BFAR" style="height: 65px; margin-right: 25px;">
        
        <div style="font-size: 12px; line-height: 1.3;">
          <strong>Republic of the Philippines</strong><br>
          Department of Agriculture<br>
          <strong>BUREAU OF FISHERIES AND AQUATIC RESOURCES</strong><br>
          <span style="color: #1a4d80; font-weight: bold; font-size: 14px;">REGIONAL FISHERIES OFFICE - MIMAROPA</span><br>
          Barangay Sapul, Calapan City 5200, Oriental Mindoro<br>
          Tel. No. (043) 288-6305 | Mobile No. 0917-107-2189<br>
          <span style="font-size: 11px; color: #0000EE; text-decoration: underline;">ord.mimaropa@bfar.da.gov.ph | records.mimaropa@bfar.da.gov.ph</span>
        </div>
      </div>

      <div style="text-align: center; margin-bottom: 25px;">
        <h2 style="margin: 0; letter-spacing: 3px; font-weight: bold; color: #333;">PAY SLIP</h2>
        <%
          const [y, m] = (payslip.month || '').split('-');
          const monthNames = [
            "JANUARY","FEBRUARY","MARCH","APRIL","MAY","JUNE",
            "JULY","AUGUST","SEPTEMBER","OCTOBER","NOVEMBER","DECEMBER"
          ];
          let cutoffDisplay = '';
          if (payslip.cutoff === 'FIRST_HALF') cutoffDisplay = '1st Half';
          else if (payslip.cutoff === 'SECOND_HALF') cutoffDisplay = '2nd Half';
        %>

        <strong>
          <%= m && y ? monthNames[parseInt(m) - 1] + ' ' + y : payslip.month %>
          <% if (cutoffDisplay) { %> - <%= cutoffDisplay %> <% } %>
        </strong>
      </div>


      <div style="margin-bottom: 15px; font-size: 14px; line-height: 1.6;">
        <strong>Name: <%= (payslip.employee_name || '').toUpperCase() %></strong><br>
        <strong>Account No.: <%= payslip.account_no %></strong>
      </div>
      
     
      <table style="width: 100%; border-collapse: collapse; border: 2px solid #000; font-size: 13px;">
        <thead>
          <tr style="text-align: center; font-weight: bold; background-color: #c0ecf8; -webkit-print-color-adjust: exact; print-color-adjust: exact;">
            <td style="border: 1px solid #000; width: 25%; padding: 8px;">EARNINGS</td>
            <td style="border: 1px solid #000; width: 20%; padding: 8px;">Amount</td>
            <td style="border: 1px solid #000; width: 35%; padding: 8px;">DEDUCTIONS</td>
            <td style="border: 1px solid #000; width: 20%; padding: 8px;">Amount</td>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td style="border-right: 1px solid #000; padding: 8px; vertical-align: top;">Basic Pay</td>
            <td style="border-right: 1px solid #000; padding: 8px; text-align: right; vertical-align: top;">
              <%= Number(payslip.basic_pay || 0).toLocaleString(undefined, {minimumFractionDigits: 2}) %>
            </td>
            
            <td style="border-right: 1px solid #000; padding: 0;">
              <div style="border-bottom: 1px solid #eee; padding: 6px 8px;">LATE/ABSENCES</div>
              <div style="border-bottom: 1px solid #eee; padding: 6px 8px;">PAG-IBIG (MP1)</div>
              <div style="border-bottom: 1px solid #eee; padding: 6px 8px;">PAG-IBIG (MP2)</div>
              <div style="border-bottom: 1px solid #eee; padding: 6px 8px;">PAG-IBIG (MPL)</div>
              <div style="border-bottom: 1px solid #eee; padding: 6px 8px;">PAG-IBIG (Calamity Loan)</div>
              <div style="border-bottom: 1px solid #eee; padding: 6px 8px;">SSS</div>
              <div style="border-bottom: 1px solid #eee; padding: 6px 8px;">PHILHEALTH</div>
              <div style="border-bottom: 1px solid #eee; padding: 6px 8px;">TAX</div>
              <div style="padding: 6px 8px;">DISALLOWANCES</div>
            </td>
            
            <td style="padding: 0; text-align: right;">
              <div style="border-bottom: 1px solid #eee; padding: 6px 8px;"><%= Number(payslip.late_absences || 0).toLocaleString(undefined, {minimumFractionDigits: 2}) %></div>
              <div style="border-bottom: 1px solid #eee; padding: 6px 8px;"><%= Number(payslip.pagibig_mp1 || 0).toLocaleString(undefined, {minimumFractionDigits: 2}) %></div>
              <div style="border-bottom: 1px solid #eee; padding: 6px 8px;"><%= Number(payslip.pagibig_mp2 || 0).toLocaleString(undefined, {minimumFractionDigits: 2}) %></div>
              <div style="border-bottom: 1px solid #eee; padding: 6px 8px;"><%= Number(payslip.pagibig_mpl || 0).toLocaleString(undefined, {minimumFractionDigits: 2}) %></div>
              <div style="border-bottom: 1px solid #eee; padding: 6px 8px;"><%= Number(payslip.pagibig_calamity || 0).toLocaleString(undefined, {minimumFractionDigits: 2}) %></div>
              <div style="border-bottom: 1px solid #eee; padding: 6px 8px;"><%= Number(payslip.sss || 0).toLocaleString(undefined, {minimumFractionDigits: 2}) %></div>
              <div style="border-bottom: 1px solid #eee; padding: 6px 8px;"><%= Number(payslip.philhealth || 0).toLocaleString(undefined, {minimumFractionDigits: 2}) %></div>
              <div style="border-bottom: 1px solid #eee; padding: 6px 8px;"><%= Number(payslip.tax || 0).toLocaleString(undefined, {minimumFractionDigits: 2}) %></div>
              <div style="padding: 6px 8px;"><%= Number(payslip.disallowances || 0).toLocaleString(undefined, {minimumFractionDigits: 2}) %></div>
            </td>
          </tr>

          <tr style="font-weight: bold;">
            <td style="border: 1px solid #000; padding: 8px;">Total Earnings</td>
            <td style="border: 1px solid #000; padding: 8px; text-align: right;"><%= Number(payslip.basic_pay || 0).toLocaleString(undefined, {minimumFractionDigits: 2}) %></td>
            <td style="border: 1px solid #000; padding: 8px; text-align: right;">Total Deductions</td>
            <td style="border: 1px solid #000; padding: 8px; text-align: right;"><%= Number(payslip.totalDeductions || 0).toLocaleString(undefined, {minimumFractionDigits: 2}) %></td>
          </tr>

          <tr>
            <td colspan="2" style="border: none;"></td>
            <td style="border: 1px solid #000; padding: 8px; text-align: right; font-weight: bold; background-color: #c0ecf8; -webkit-print-color-adjust: exact; print-color-adjust: exact;">Net Pay</td>
            <td style="border: 1px solid #000; padding: 8px; text-align: right; font-weight: bold; background-color: #c0ecf8; -webkit-print-color-adjust: exact; print-color-adjust: exact;"><%= Number(payslip.netPay || 0).toLocaleString(undefined, {minimumFractionDigits: 2}) %></td>
          </tr>
        </tbody>
      </table>

      <div style="margin-top: 15px; text-align: right; font-size: 12px;">
        <em>Prepared by: HRMU</em>
      </div>

    </div>
</body>
<script nonce="<%= nonce %>">
    window.onload = function() { window.print(); };
</script>
</html>