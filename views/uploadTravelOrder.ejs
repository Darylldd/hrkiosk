<!DOCTYPE html>
<html lang="en" class="">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Upload Travel Order</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      darkMode: 'class',
      theme: {
        extend: {
          fontFamily: {
            display: ['"Playfair Display"', 'Georgia', 'serif'],
            body:    ['"DM Sans"', 'sans-serif'],
          },
          colors: {
            navy: {
              50:'#eef2f7',100:'#d5e0ed',200:'#abc1db',300:'#7599be',
              400:'#4a72a0',500:'#1a5276',600:'#154464',700:'#103552',
              800:'#0b2640',900:'#06192e',
            },
          },
        },
      },
    };
  </script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&family=Playfair+Display:wght@600&display=swap" rel="stylesheet" />
  <style>
    body { font-family: 'DM Sans', sans-serif; }
    @keyframes fade-in    { from { opacity:0; transform:translateY(8px);  } to { opacity:1; transform:translateY(0); } }
    @keyframes slide-down { from { opacity:0; transform:translateY(-6px); } to { opacity:1; transform:translateY(0); } }
    .page-in  { animation: fade-in    0.35s ease forwards; }
    .alert-in { animation: slide-down 0.3s  ease forwards; }
  </style>
</head>

<body class="min-h-screen bg-slate-100 dark:bg-slate-950 transition-colors duration-300">

  <!-- ── Nav ────────────────────────────────────────────── -->
  <header class="sticky top-0 z-30 bg-white dark:bg-slate-900 border-b border-slate-200 dark:border-slate-800 shadow-sm">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 h-16 flex items-center justify-between gap-4">
      <a href="/dashboard" class="flex items-center gap-2.5 group">
        <div class="flex items-center justify-center w-9 h-9 rounded-lg bg-navy-500 dark:bg-navy-600 shrink-0">
          <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
          </svg>
        </div>
        <span class="font-display text-lg text-navy-700 dark:text-navy-200 hidden sm:block group-hover:text-navy-500 transition-colors">Employee Portal</span>
      </a>
      <div class="flex items-center gap-2">
        <button id="themeToggle" aria-label="Toggle dark mode"
          class="p-2 rounded-lg border border-slate-200 dark:border-slate-700 text-slate-500 dark:text-slate-400
                 bg-white dark:bg-slate-800 hover:text-navy-500 dark:hover:text-navy-300 transition-all duration-200">
          <svg class="hidden dark:block w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707M17.657 17.657l-.707-.707M6.343 6.343l-.707-.707M12 8a4 4 0 100 8 4 4 0 000-8z"/></svg>
          <svg class="block dark:hidden w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/></svg>
        </button>
        <a href="/travel-orders" class="flex items-center gap-1.5 px-3 py-2 rounded-lg text-sm font-medium
               border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800
               text-slate-600 dark:text-slate-300 hover:text-navy-600 dark:hover:text-navy-300
               hover:bg-navy-50 dark:hover:bg-navy-900/20 transition-all duration-200">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
          <span class="hidden sm:inline">Travel Orders</span>
        </a>
      </div>
    </div>
  </header>

  <!-- ── Body ───────────────────────────────────────────── -->
  <main class="max-w-4xl mx-auto px-4 sm:px-6 py-8 page-in">

    <div class="mb-6">
      <h1 class="font-display text-2xl text-navy-700 dark:text-navy-200">Upload Travel Order</h1>
      <p class="text-sm text-slate-500 dark:text-slate-400 mt-0.5">Fill in the details and attach the travel order document</p>
    </div>

    <!-- Alert -->
    <% if (locals.msg) { %>
      <% const isSuccess = !msg.toLowerCase().includes('error') && !msg.toLowerCase().includes('missing'); %>
      <div role="alert" class="alert-in mb-6 flex items-start gap-3 px-4 py-3 rounded-xl
           <%= isSuccess
             ? 'bg-green-50 dark:bg-green-900/25 border border-green-200 dark:border-green-800 text-green-700 dark:text-green-400'
             : 'bg-red-50 dark:bg-red-900/25 border border-red-200 dark:border-red-800 text-red-700 dark:text-red-400' %>">
        <% if (isSuccess) { %>
          <svg class="w-5 h-5 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        <% } else { %>
          <svg class="w-5 h-5 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/></svg>
        <% } %>
        <span class="text-sm font-medium"><%= msg %></span>
      </div>
    <% } %>

    <!-- Shared input class -->
    <% const inp = "w-full px-3 py-2.5 text-sm rounded-lg border border-slate-200 dark:border-slate-600 bg-slate-50 dark:bg-slate-900 text-slate-800 dark:text-slate-100 placeholder-slate-400 dark:placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-navy-400 dark:focus:ring-navy-500 focus:border-transparent transition"; %>
    <% const ta  = inp + " resize-none"; %>
    <% const lbl = "block text-xs font-semibold uppercase tracking-wide text-slate-500 dark:text-slate-400 mb-1.5"; %>

    <form method="POST" enctype="multipart/form-data" class="space-y-5">

      <!-- Trip Details -->
      <div class="bg-white dark:bg-slate-800 rounded-xl border border-slate-200 dark:border-slate-700 p-6">
        <h2 class="text-xs font-semibold uppercase tracking-widest text-slate-400 dark:text-slate-500 mb-5">Trip Details</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">

          <div>
            <label for="to_no" class="<%= lbl %>">TO Number <span class="text-red-400">*</span></label>
            <input id="to_no" name="to_no" type="text" placeholder="e.g. TO-2024-001" required class="<%= inp %>" />
          </div>

          <div>
            <label for="travel_date" class="<%= lbl %>">Departure Date <span class="text-red-400">*</span></label>
            <input id="travel_date" name="travel_date" type="date" required class="<%= inp %>" />
          </div>

          <div>
            <label for="return_date" class="<%= lbl %>">Return Date <span class="text-red-400">*</span></label>
            <input id="return_date" name="return_date" type="date" required class="<%= inp %>" />
          </div>

          <div class="sm:col-span-2 lg:col-span-3">
            <label for="destination" class="<%= lbl %>">Destination <span class="text-red-400">*</span></label>
            <input id="destination" name="destination" type="text" placeholder="City / Province / Region" required class="<%= inp %>" />
          </div>

        </div>
      </div>

      <!-- Employees -->
      <div class="bg-white dark:bg-slate-800 rounded-xl border border-slate-200 dark:border-slate-700 p-6">
        <div class="flex items-center justify-between mb-5">
          <h2 class="text-xs font-semibold uppercase tracking-widest text-slate-400 dark:text-slate-500">Employees</h2>
          <button type="button" id="addEmployeeBtn"
            class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-xs font-medium
                   border border-slate-200 dark:border-slate-600 bg-slate-50 dark:bg-slate-900
                   text-slate-600 dark:text-slate-300 hover:border-navy-400 hover:text-navy-600
                   dark:hover:text-navy-300 transition-all duration-200">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
            Add Employee
          </button>
        </div>

        <div id="employees-container" class="space-y-3">
          <!-- First row (template) -->
          <div class="employee-row flex flex-col sm:flex-row gap-3 p-3 rounded-lg bg-slate-50 dark:bg-slate-900 border border-slate-200 dark:border-slate-700">
            <div class="flex-1">
              <label class="<%= lbl %>">Employee <span class="text-red-400">*</span></label>
              <select name="employee_ids[]" required
                class="employee-select w-full px-3 py-2.5 text-sm rounded-lg border border-slate-200 dark:border-slate-600
                       bg-white dark:bg-slate-800 text-slate-800 dark:text-slate-100
                       focus:outline-none focus:ring-2 focus:ring-navy-400 dark:focus:ring-navy-500 focus:border-transparent transition">
                <option value="">Select employee...</option>
                <% employees.forEach(e => { %>
                  <option value="<%= e.id %>" data-position="<%= e.position || '' %>">
                    <%= e.first_name %> <%= e.last_name %> (<%= e.department || 'No Dept' %>)
                  </option>
                <% }) %>
              </select>
            </div>
            <div class="sm:w-64">
              <label class="<%= lbl %>">Position</label>
              <input type="text" name="positions[]" placeholder="Auto-filled from selection"
                class="<%= inp %>" />
            </div>
            <!-- Remove btn (hidden on first row) -->
            <div class="flex items-end">
              <button type="button"
                class="remove-row-btn hidden p-2 rounded-lg text-slate-400 hover:text-red-500 dark:hover:text-red-400
                       hover:bg-red-50 dark:hover:bg-red-900/20 border border-transparent
                       hover:border-red-200 dark:hover:border-red-800 transition-all duration-200"
                aria-label="Remove this row">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
              </button>
            </div>
          </div>
        </div>
      </div>

      <!-- Purpose & Objectives -->
      <div class="bg-white dark:bg-slate-800 rounded-xl border border-slate-200 dark:border-slate-700 p-6">
        <h2 class="text-xs font-semibold uppercase tracking-widest text-slate-400 dark:text-slate-500 mb-5">Purpose &amp; Objectives</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">

          <div class="sm:col-span-2">
            <label for="specific_purpose" class="<%= lbl %>">Specific Purpose of Travel</label>
            <textarea id="specific_purpose" name="specific_purpose" rows="3" placeholder="Describe the travel purpose..."
              class="<%= ta %>"></textarea>
          </div>

          <div>
            <label for="objectives" class="<%= lbl %>">Objectives</label>
            <textarea id="objectives" name="objectives" rows="3" placeholder="List objectives..."
              class="<%= ta %>"></textarea>
          </div>

          <div>
            <label for="per_diems_allowed" class="<%= lbl %>">Per Diems Allowed</label>
            <textarea id="per_diems_allowed" name="per_diems_allowed" rows="3" placeholder="e.g. P1,000.00/day"
              class="<%= ta %>"></textarea>
          </div>

          <div>
            <label for="appropriation" class="<%= lbl %>">Appropriation to be Charged</label>
            <textarea id="appropriation" name="appropriation" rows="3" placeholder="Fund source..."
              class="<%= ta %>"></textarea>
          </div>

          <div>
            <label for="remarks" class="<%= lbl %>">Remarks / Special Instructions</label>
            <textarea id="remarks" name="remarks" rows="3" placeholder="Additional notes..."
              class="<%= ta %>"></textarea>
          </div>

        </div>
      </div>

      <!-- Administrative -->
      <div class="bg-white dark:bg-slate-800 rounded-xl border border-slate-200 dark:border-slate-700 p-6">
        <h2 class="text-xs font-semibold uppercase tracking-widest text-slate-400 dark:text-slate-500 mb-5">Administrative Details</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">

          <div>
            <label for="salary_per_diem" class="<%= lbl %>">Salary / Per Diem</label>
            <input id="salary_per_diem" name="salary_per_diem" type="text" placeholder="e.g. P45,203.00"
              class="<%= inp %>" />
          </div>

          <div>
            <label for="office_station" class="<%= lbl %>">Office Station</label>
            <input id="office_station" name="office_station" type="text"
              value="<%= order.office_station || '' %>" class="<%= inp %>" />
          </div>

          <div>
            <label for="contact_number" class="<%= lbl %>">Contact Number</label>
            <input id="contact_number" name="contact_number" type="text"
              value="<%= order.contact_number || '' %>" placeholder="+63 9XX XXX XXXX" class="<%= inp %>" />
          </div>

          <div>
            <label for="recommending_approval" class="<%= lbl %>">Recommending Approval</label>
            <input id="recommending_approval" name="recommending_approval" type="text"
              value="<%= order.recommending_approval || '' %>" placeholder="Full name"
              class="<%= inp %>" />
          </div>

          <div>
            <label for="recommending_position" class="<%= lbl %>">Recommending Position</label>
            <input id="recommending_position" name="recommending_position" type="text"
              placeholder="Position / Designation" class="<%= inp %>" />
          </div>

          <div>
            <label for="approved_by" class="<%= lbl %>">Approved By</label>
            <input id="approved_by" name="approved_by" type="text"
              placeholder="Full name" class="<%= inp %>" />
          </div>

        </div>
      </div>

      <!-- File Upload -->
      <div class="bg-white dark:bg-slate-800 rounded-xl border border-slate-200 dark:border-slate-700 p-6">
        <h2 class="text-xs font-semibold uppercase tracking-widest text-slate-400 dark:text-slate-500 mb-5">Document Attachment <span class="text-red-400">*</span></h2>
        <div class="flex items-center gap-4">
          <label for="fileUpload"
            class="cursor-pointer flex items-center gap-2 px-4 py-2.5 rounded-xl text-sm font-medium
                   border-2 border-dashed border-slate-200 dark:border-slate-600
                   bg-slate-50 dark:bg-slate-900 text-slate-600 dark:text-slate-300
                   hover:border-navy-400 dark:hover:border-navy-500 hover:text-navy-600 dark:hover:text-navy-300
                   transition-all duration-200 w-full sm:w-auto">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/></svg>
            Choose File
          </label>
          <input id="fileUpload" type="file" name="file" required class="hidden" />
          <p id="fileLabel" class="text-sm text-slate-400 dark:text-slate-500">PDF, JPG, or PNG · max 10 MB</p>
        </div>
      </div>

      <!-- Submit bar -->
      <div class="flex items-center justify-end gap-3 pt-2">
        <a href="/travel-orders" class="px-5 py-2.5 rounded-xl text-sm font-medium
               border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800
               text-slate-600 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-700 transition-all duration-200">
          Cancel
        </a>
        <button type="submit"
          class="flex items-center gap-2 px-6 py-2.5 rounded-xl text-sm font-semibold
                 bg-navy-500 hover:bg-navy-600 dark:bg-navy-600 dark:hover:bg-navy-500
                 text-white shadow-md hover:shadow-lg active:scale-[0.98] transition-all duration-200
                 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-navy-400">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/></svg>
          Upload Travel Order
        </button>
      </div>

    </form>
  </main>

  <script nonce="<%= nonce %>">
    // ── Theme ──────────────────────────────────────────────────
    const html = document.documentElement;
    const stored = localStorage.getItem('theme');
    if (stored === 'dark' || (!stored && window.matchMedia('(prefers-color-scheme: dark)').matches)) html.classList.add('dark');
    document.getElementById('themeToggle').addEventListener('click', () => {
      html.classList.toggle('dark');
      localStorage.setItem('theme', html.classList.contains('dark') ? 'dark' : 'light');
    });

    // ── File label ─────────────────────────────────────────────
    document.getElementById('fileUpload').addEventListener('change', function () {
      document.getElementById('fileLabel').textContent =
        this.files[0] ? this.files[0].name : 'PDF, JPG, or PNG · max 10 MB';
    });

    // ── Employee rows ──────────────────────────────────────────
    const container = document.getElementById('employees-container');

    // Auto-fill position when employee is selected
    container.addEventListener('change', function (e) {
      if (!e.target.classList.contains('employee-select')) return;
      const opt = e.target.options[e.target.selectedIndex];
      const row = e.target.closest('.employee-row');
      const posInput = row.querySelector('input[name="positions[]"]');
      posInput.value = opt.getAttribute('data-position') || '';
    });

    // Add employee row
    document.getElementById('addEmployeeBtn').addEventListener('click', function () {
      const firstRow  = container.querySelector('.employee-row');
      const newRow    = firstRow.cloneNode(true);
      // Reset values
      newRow.querySelector('select').value           = '';
      newRow.querySelector('input[name="positions[]"]').value = '';
      // Show remove button on cloned rows
      newRow.querySelector('.remove-row-btn').classList.remove('hidden');
      container.appendChild(newRow);
      updateRemoveBtns();
    });

    // Remove row
    container.addEventListener('click', function (e) {
      const btn = e.target.closest('.remove-row-btn');
      if (!btn) return;
      btn.closest('.employee-row').remove();
      updateRemoveBtns();
    });

    function updateRemoveBtns() {
      const rows = container.querySelectorAll('.employee-row');
      rows.forEach((row, idx) => {
        const btn = row.querySelector('.remove-row-btn');
        btn.classList.toggle('hidden', rows.length === 1);
      });
    }
  </script>
</body>
</html>
