<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Create Gov't Payslip</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            background-color: #f4f4f4;
            display: flex;
            justify-content: center;
            padding: 20px;
        }
        .payslip-container {
            background-color: #fff;
            width: 900px;
            padding: 20px 40px;
            box-shadow: 0 0 10px rgba(0,0,0,0.1);
            position: relative;
            box-sizing: border-box;
        }
        .top-banner {
            position: absolute;
            top: 0;
            left: 0;
            width: 35%;
            height: auto;
            max-height: 90px;
            z-index: 1;
        }
        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-top: 20px;
            position: relative;
            z-index: 2;
            text-align: center;
            font-size: 12px;
        }
        .header img {
            height: 80px;
        }
        .header-text {
            flex-grow: 1;
            line-height: 1.4;
        }
        .header-text h3, .header-text h4, .header-text p {
            margin: 2px 0;
            font-weight: bold;
        }
        .header-text h3 { font-size: 14px; }
        .header-text p.subtext { font-weight: normal; font-size: 11px; }

        .payslip-title {
            text-align: center;
            margin: 20px 0;
        }
        .payslip-title h2 { margin: 0; font-size: 20px; letter-spacing: 5px; }

        .employee-info {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 10px;
            margin-bottom: 20px;
            font-size: 13px;
            font-weight: bold;
            align-items: center;
        }

        /* ── SCREENSHOT TOUCH: tighter border style on main table ── */
        table {
            width: 100%;
            border-collapse: collapse;
            font-size: 12px;
        }
        th, td {
            border: 1px solid #555;
            padding: 6px;
        }
        .no-border-table th, .no-border-table td {
            border: none;
            padding: 4px 6px;
        }
        .text-right { text-align: right; }
        .bold { font-weight: bold; }
        .valign-top { vertical-align: top; }

        .main-table > tbody > tr > td.container-cell {
            padding: 0;
        }

        /* ── SCREENSHOT TOUCH: dashed vertical separators between columns ── */
        .main-table > thead > tr > th {
            border: 1px solid #555;
            background-color: #f9f9f9;
            font-size: 12px;
            text-align: center;
        }
        .main-table > thead > tr > th:not(:last-child) {
            border-right: 1px dashed #777;
        }
        .main-table > tbody > tr > td.container-cell:not(:last-child) {
            border-right: 1px dashed #777;
        }

        /* ── SCREENSHOT TOUCH: totals row ── */
        .totals-row td {
            border-top: 2px solid #333;
            border-bottom: 1px solid #555;
            font-weight: bold;
            font-size: 12px;
            padding: 5px 8px;
            background-color: #fafafa;
        }
        .totals-row td:not(:last-child) {
            border-right: 1px dashed #777;
        }
        .totals-val {
            display: inline-block;
            border-bottom: 2px solid #333;
            min-width: 80px;
            text-align: right;
            padding: 0 3px;
        }

        /* Form Specific Styles */
        .input-field {
            width: 80px;
            padding: 3px;
            border: 1px solid #ccc;
            border-radius: 3px;
            font-size: 11px;
            text-align: right;
        }
        .input-field-text {
            width: 150px;
            padding: 3px;
            border: 1px solid #ccc;
            border-radius: 3px;
            font-size: 11px;
        }
        .input-field:focus, .input-field-text:focus, .select-field:focus {
            outline: none;
            border-color: #4CAF50;
        }
        .select-field {
            padding: 4px;
            font-size: 14px;
            border: 1px solid #ccc;
            border-radius: 3px;
        }

        /* 2-Column Grid for Deductions */
        .deduction-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 4px 15px;
            padding: 8px;
        }
        .deduction-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-size: 11px;
        }
        .deduction-item span {
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            margin-right: 5px;
        }

        .actions {
            margin-top: 30px;
            text-align: center;
        }
        .actions button {
            padding: 10px 20px;
            background-color: #4CAF50;
            color: white;
            border: none;
            cursor: pointer;
            font-size: 14px;
            border-radius: 4px;
        }
        .actions button.add-btn {
            background-color: #007bff;
            padding: 5px 10px;
            font-size: 11px;
            margin: 10px 0;
        }
        .actions a {
            margin-left: 10px;
            text-decoration: none;
            color: #d9534f;
            font-size: 14px;
        }
        .remove-btn {
            background-color: #d9534f;
            color: white;
            border: none;
            padding: 3px 5px;
            border-radius: 3px;
            cursor: pointer;
            font-size: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        /* ── SCREENSHOT TOUCH: employee info rows styled like the doc ── */
        .emp-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            border: 1px solid #555;
            border-bottom: none;
            font-size: 12px;
            font-weight: bold;
        }
        .emp-row:last-child { border-bottom: 1px solid #555; }
        .emp-cell {
            padding: 4px 8px;
            display: flex;
            align-items: center;
            gap: 6px;
        }
        .emp-cell:first-child { border-right: 1px solid #555; }
        .emp-cell input[type="text"] {
            width: 180px;
            padding: 2px 4px;
            border: none;
            border-bottom: 1px solid #888;
            font-size: 12px;
            outline: none;
            background: transparent;
            font-family: Arial, sans-serif;
        }
    </style>
</head>
<body>

<div class="payslip-container">
    <img src="/images/uhi.png" class="top-banner" alt="Green and Yellow Banner">

    <div class="header">
        <img src="/images/ggggg.jpg" alt="DA and BFAR Logos">
        <div class="header-text">
            <h4>Republic of the Philippines</h4>
            <h4>Department of Agriculture</h4>
            <h3>BUREAU OF FISHERIES AND AQUATIC RESOURCES</h3>
            <p>REGIONAL FISHERIES OFFICE - MIMAROPA</p>
            <p class="subtext">Sapul, Calapan City 5200, Oriental Mindoro</p>
            <p class="subtext">Tel. No. (043) 288-6305 | Mobile No. 0917-107-2189</p>
            <p class="subtext" style="color: blue;">ord.mimaropa@bfar.da.gov.ph | records.mimaropa@bfar.da.gov.ph</p>
        </div>
        <img src="/images/lho.png" alt="Bagong Pilipinas Logo">
    </div>

    <form action="/admin/payslip/preview" method="POST">
        <input type="hidden" name="employee_id" value="<%= employee ? employee.id : '' %>">

        <div class="payslip-title">
            <h2>C R E A T E &nbsp;P A Y S L I P</h2>
            <div style="margin-top: 10px;">
                <select name="month" class="select-field" required>
                    <option value="" disabled selected>Select Month</option>
                    <option value="January">January</option>
                    <option value="February">February</option>
                    <option value="March">March</option>
                    <option value="April">April</option>
                    <option value="May">May</option>
                    <option value="June">June</option>
                    <option value="July">July</option>
                    <option value="August">August</option>
                    <option value="September">September</option>
                    <option value="October">October</option>
                    <option value="November">November</option>
                    <option value="December">December</option>
                </select>
                <input type="number" name="year" value="2025" class="select-field" style="width: 70px;" required>
            </div>
        </div>

        <!-- Employee info styled like screenshot rows -->
        <div class="emp-row">
            <div class="emp-cell">
                EMPL NAME:&nbsp;<span><%= employee ? (employee.first_name + ' ' + (employee.middle_name || '') + ' ' + employee.last_name) : 'N/A' %></span>
            </div>
            <div class="emp-cell">
                DIVISION:&nbsp;<input type="text" name="division">
            </div>
        </div>
        <div class="emp-row">
            <div class="emp-cell">
                POSITION:&nbsp;<span><%= employee ? employee.position : 'N/A' %></span>
            </div>
            <div class="emp-cell">
                SECTION:&nbsp;<input type="text" name="section">
            </div>
        </div>

        <table class="main-table">
            <thead>
                <tr>
                    <th style="width: 25%;">GROSS EARNINGS</th>
                    <th style="width: 50%;">DEDUCTIONS</th>
                    <th style="width: 25%;">PERIODS</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <!-- GROSS EARNINGS -->
                    <td class="valign-top container-cell">
                        <table class="no-border-table" style="width: 100%;">
                            <tr>
                                <td>Monthly Salary</td>
                                <td class="text-right"><input type="number" step="0.01" name="monthly_salary" class="input-field" required></td>
                            </tr>
                            <tr>
                                <td>PERA (Fixed)</td>
                                <td class="text-right">&#8369; 2,000.00</td>
                            </tr>
                        </table>
                    </td>

                    <!-- DEDUCTIONS -->
                    <td class="valign-top container-cell">
                        <div class="deduction-grid">
                            <div class="deduction-item"><span>GSIS Per Share:</span> <input type="number" step="0.01" name="gsis_per_share" class="input-field"></div>
                            <div class="deduction-item"><span>Medicare 5%:</span> <input type="number" step="0.01" name="medicare" class="input-field"></div>
                            <div class="deduction-item"><span>Pag Ibig:</span> <input type="number" step="0.01" name="pagibig" class="input-field"></div>
                            <div class="deduction-item"><span>Withholding Tax:</span> <input type="number" step="0.01" name="withholding_tax" class="input-field"></div>
                            <div class="deduction-item"><span>403 Provident Fund:</span> <input type="number" step="0.01" name="provident_403" class="input-field"></div>
                            <div class="deduction-item"><span>337 GSIS-Emerg:</span> <input type="number" step="0.01" name="gsis_emerg_337" class="input-field"></div>
                            <div class="deduction-item"><span>346 GSIS-MPL:</span> <input type="number" step="0.01" name="gsis_mpl_346" class="input-field"></div>
                            <div class="deduction-item"><span>440 HDMF-MPL:</span> <input type="number" step="0.01" name="hdmf_mpl_440" class="input-field"></div>
                            <div class="deduction-item"><span>ISLAI-Premium:</span> <input type="number" step="0.01" name="islai_premium" class="input-field"></div>
                            <div class="deduction-item"><span>ISLAI-Loan:</span> <input type="number" step="0.01" name="islai_loan" class="input-field"></div>
                            <div class="deduction-item"><span>HDMF-CAL:</span> <input type="number" step="0.01" name="hdmf_cal" class="input-field"></div>
                            <div class="deduction-item"><span>UCPB Loan:</span> <input type="number" step="0.01" name="ucpb_loan" class="input-field"></div>
                            <div class="deduction-item"><span>ISLAI-Emergency:</span> <input type="number" step="0.01" name="islai_emergency" class="input-field"></div>
                            <div class="deduction-item"><span>GSIS-CPL:</span> <input type="number" step="0.01" name="gsis_cpl" class="input-field"></div>
                            <div class="deduction-item"><span>GSIS-MPL LITE:</span> <input type="number" step="0.01" name="gsis_mpl_lite" class="input-field"></div>
                            <div class="deduction-item"><span>UCPB KASAMA MO:</span> <input type="number" step="0.01" name="ucpb_kasama_salary" class="input-field"></div>
                            <div class="deduction-item"><span>GSIS-Policy Reg:</span> <input type="number" step="0.01" name="gsis_policy_regular" class="input-field"></div>
                            <div class="deduction-item"><span>PAL-DA Capital:</span> <input type="number" step="0.01" name="palda_capital_share" class="input-field"></div>
                            <div class="deduction-item"><span>PAL-DA CoopBank:</span> <input type="number" step="0.01" name="palda_coopbank_share" class="input-field"></div>
                            <div class="deduction-item"><span>BFAR Coop Addt'l:</span> <input type="number" step="0.01" name="bfar_coop_additional" class="input-field"></div>
                            <div class="deduction-item"><span>PAL-DA Regular:</span> <input type="number" step="0.01" name="palda_regular" class="input-field"></div>
                        </div>

                      <div id="deductions-container" style="padding: 0 8px 4px;"></div>

                        <div style="text-align: center; margin-bottom: 10px;">
<button type="button" class="add-btn" id="addDeductionBtn">+ Add Other Deduction</button>
                        </div>
                    </td>

                    <!-- PERIODS -->
                    <td class="valign-top container-cell">
                        <table class="no-border-table" style="width: 100%;">
                            <tr>
                                <td class="bold">1ST PERIOD</td>
                                <td class="text-right"><input type="number" step="0.01" name="first_period" class="input-field"></td>
                            </tr>
                            <tr>
                                <td class="bold">2ND PERIOD</td>
                                <td class="text-right"><input type="number" step="0.01" name="second_period" class="input-field"></td>
                            </tr>
                        </table>
                    </td>
                </tr>

           
            </tbody>
        </table>

        <div class="actions">
            <button type="submit">Preview Payslip</button>
            <a href="/admin/payslip/list">Cancel</a>
        </div>
    </form>
</div>

<script nonce="<%= nonce %>">
function addDeduction() {
    const container = document.getElementById('deductions-container');
    const row = document.createElement('div');
    row.style.cssText = "display:flex; justify-content:space-between; align-items:center; font-size:11px; margin-bottom:4px;";
    row.innerHTML = `
        <input type="text" name="deduction_name[]" class="input-field-text" style="flex:1; min-width:0; margin-right:5px;" placeholder="Name include Code if needed" required>
        <div style="display:flex; align-items:center; gap:3px;">
            <input type="number" step="0.01" name="deduction_amount[]" class="input-field" placeholder="0.00" required>
            <button type="button" class="remove-btn" title="Remove">✕</button>
        </div>
    `;
    // attach remove listener instead of inline onclick
    row.querySelector('.remove-btn').addEventListener('click', () => row.remove());
    container.appendChild(row);
}
document.getElementById('addDeductionBtn').addEventListener('click', addDeduction);
</script>

</body>
</html>