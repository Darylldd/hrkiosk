
<h2>Employee Login</h2>
<form action="/login" method="POST">
    <label>Employee No:</label><br>
    <input type="text" name="employee_no" placeholder="Employee No" required><br><br>

    <label>PIN:</label><br>
    <input type="password" name="pin" placeholder="PIN" required><br><br>

    <button type="submit">Login</button>
</form>