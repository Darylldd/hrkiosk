<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Payslip Preview – <%= data.month %> <%= data.year %></title>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body {
      font-family: Arial, sans-serif;
      background-color: #ffffff;
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 20px;
  }

  /* ── Action Bar ── */
  .preview-actions {
      width: 900px;
      background: #fff;
      border: 1px solid #ccc;
      border-bottom: none;
      padding: 10px 20px;
      display: flex;
      align-items: center;
      gap: 10px;
  }
  .preview-actions span { font-size: 13px; font-weight: bold; flex: 1; color: #333; }
  .btn { padding: 7px 16px; border: none; border-radius: 4px; cursor: pointer; font-size: 12px; font-weight: bold; }
  .btn-save  { background: #4CAF50; color: #fff; }
  .btn-print { background: #f39c12; color: #fff; }
  .btn-cancel {
      background: #d9534f; color: #fff; text-decoration: none;
      display: inline-block; padding: 7px 16px;
      border-radius: 4px; font-size: 12px; font-weight: bold;
  }

  /* ── Payslip Container ── */
  .payslip-container {
      background-color: #fff;
      width: 900px;
      padding: 20px 40px 30px;
      box-shadow: 0 0 10px rgba(0,0,0,0.1);
      position: relative;
  }
  .top-banner {
      position: absolute;
      top: 0; left: 0;
      width: 35%; height: auto; max-height: 90px;
      z-index: 1;
  }

  /* ── Header ── */
  .header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-top: 20px;
      position: relative;
      z-index: 2;
      font-size: 12px;
  }
  .header img { height: 80px; }
  .header-text { flex-grow: 1; text-align: center; line-height: 1.45; }
  .header-text h3, .header-text h4, .header-text p { margin: 1px 0; font-weight: bold; }
  .header-text h3 { font-size: 14px; }
  .header-text p.subtext { font-weight: normal; font-size: 11px; }

  /* ── Title block ── */
  .payslip-title {
      margin: 14px 0 0;
      border-top: 2px solid #333;
      padding-top: 4px;
  }
  .payslip-title .ps-label  { font-size: 13px; font-weight: bold; letter-spacing: 2px; }
  .payslip-title .ps-period { font-size: 12px; font-weight: bold; margin-top: 1px; }

  /* ── Employee info rows ── */
  .emp-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      border: 1px solid #555;
      border-bottom: none;
      font-size: 12px;
      font-weight: bold;
  }
  .emp-row:last-child { border-bottom: 1px solid #555; }
  .emp-cell { padding: 3px 8px; display: flex; align-items: center; gap: 4px; }
  .emp-cell:first-child { border-right: 1px solid #555; }

  /* ── Main table ── */
  .main-table { width: 100%; border-collapse: collapse; font-size: 11px; }

  .main-table th {
      border: 1px solid #555;
      padding: 4px 8px;
      background-color: #f0f0f0;
      font-size: 11px;
      font-weight: bold;
      text-align: center;
  }
  .main-table th:not(:last-child) { border-right: 1px dashed #777; }

  /* body column cells */
  .main-table td.col {
      border: 1px solid #555;
      padding: 0;
      vertical-align: top;
  }
  .main-table td.col:not(:last-child) { border-right: 1px dashed #777; }

  /* totals footer */
  .main-table tr.tfoot td {
      border: 1px solid #555;
      border-top: 2px solid #333;
      padding: 4px 8px;
      font-weight: bold;
      font-size: 11px;
      background: #fafafa;
  }
  .main-table tr.tfoot td:not(:last-child) { border-right: 1px dashed #777; }

  /* inner borderless tables */
  .inner { width: 100%; border-collapse: collapse; }
  .inner td { border: none; padding: 2px 6px; font-size: 11px; }
  .inner td.r { text-align: right; white-space: nowrap; }
  .inner td.b { font-weight: bold; }

  @media print {
      .preview-actions { display: none; }
      body { background: #fff; padding: 0; }
      .payslip-container { box-shadow: none; width: 100%; }
  }
</style>
</head>
<body>

<!-- Action Bar -->
<div class="preview-actions">
  <span>📄 Payslip Preview – <%= data.month %> <%= data.year %></span>
<button class="btn btn-save"  id="saveBtn">✔ Confirm &amp; Save</button>
<button class="btn btn-print" id="printBtn">🖨 Print</button>
  <a class="btn-cancel" href="javascript:history.back()">✕ Back to Edit</a>
</div>

<!-- Hidden save form -->
<form id="saveForm" action="/admin/payslip/save" method="POST" style="display:none;">
  <input type="hidden" name="employee_id"    value="<%= data.employee_id %>">
  <input type="hidden" name="month"          value="<%= data.month %>">
  <input type="hidden" name="year"           value="<%= data.year %>">
  <input type="hidden" name="division"       value="<%= data.division %>">
  <input type="hidden" name="section"        value="<%= data.section %>">
  <input type="hidden" name="monthly_salary" value="<%= data.monthly_salary %>">
  <% const fixedFields = [
    'gsis_per_share','medicare','pagibig','withholding_tax',
    'provident_403','gsis_emerg_337','gsis_mpl_346','hdmf_mpl_440',
    'islai_premium','islai_loan','hdmf_cal','ucpb_loan',
    'islai_emergency','gsis_cpl','gsis_mpl_lite','ucpb_kasama_salary',
    'gsis_policy_regular','palda_capital_share','palda_coopbank_share',
    'bfar_coop_additional','palda_regular'
  ]; %>
  <% fixedFields.forEach(f => { %><input type="hidden" name="<%= f %>" value="<%= data[f] || 0 %>"><% }); %>
  <% other_deductions.forEach(d => { %>
    <input type="hidden" name="deduction_name[]"   value="<%= d.name %>">
    <input type="hidden" name="deduction_amount[]" value="<%= d.amount %>">
  <% }); %>
  <input type="hidden" name="first_period"  value="<%= data.first_period  || 0 %>">
  <input type="hidden" name="second_period" value="<%= data.second_period || 0 %>">
</form>

<!-- Payslip Document -->
<div class="payslip-container">

  <img src="/images/uhi.png" class="top-banner" alt="Banner">

  <!-- Header -->
  <div class="header">
    <img src="/images/ggggg.jpg" alt="DA and BFAR Logos">
    <div class="header-text">
      <h4>Republic of the Philippines</h4>
      <h4>Department of Agriculture</h4>
      <h3>BUREAU OF FISHERIES AND AQUATIC RESOURCES</h3>
      <p>REGIONAL FISHERIES OFFICE - MIMAROPA</p>
      <p class="subtext">Sapul, Calapan City 5200, Oriental Mindoro</p>
      <p class="subtext">Tel. No. (043) 288-6305 | Mobile No. 0917-107-2189</p>
      <p class="subtext" style="color:blue;">ord.mimaropa@bfar.da.gov.ph | records.mimaropa@bfar.da.gov.ph</p>
    </div>
    <img src="/images/lho.png" alt="Bagong Pilipinas Logo">
  </div>

  <!-- Title -->
  <div class="payslip-title">
    <div class="ps-label">P A Y S L I P</div>
    <div class="ps-period"><%= data.month.toUpperCase() %> &nbsp;<%= data.year %></div>
  </div>

  <!-- Employee Info -->
  <div class="emp-row">
    <div class="emp-cell">EMPL NAME:&nbsp;<span><%= employee.first_name %> <%= employee.middle_name || '' %> <%= employee.last_name %></span></div>
    <div class="emp-cell">DIVISION:&nbsp;<span><%= data.division || 'N/A' %></span></div>
  </div>
  <div class="emp-row">
    <div class="emp-cell">POSITION:&nbsp;<span><%= employee.position || '' %></span></div>
    <div class="emp-cell">SECTION:&nbsp;<span><%= data.section || 'N/A' %></span></div>
  </div>

  <%
    const fmt = n => Number(n || 0).toLocaleString('en-PH', { minimumFractionDigits: 2, maximumFractionDigits: 2 });

    const labelMap = {
      gsis_per_share:       'GSIS Per Share',
      medicare:             'Medicare 5%',
      pagibig:              'Pag Ibig',
      withholding_tax:      'Withholding Tax',
      provident_403:        '403   Provident Fund',
      gsis_emerg_337:       '337   GSIS -Emerg. Loan',
      gsis_mpl_346:         '346   GSIS-MPL',
      hdmf_mpl_440:         '440   HDMF-MPL',
      islai_premium:        'ISLAI-Premium',
      islai_loan:           'ISLAI-Loan',
      hdmf_cal:             'HDMF-CAL',
      ucpb_loan:            'UCPB Loan',
      islai_emergency:      'ISLAI-Emergency',
      gsis_cpl:             'GSIS-CPL',
      gsis_mpl_lite:        'GSIS-MPL LITE',
      ucpb_kasama_salary:   'UCPB KASAMA MO',
      gsis_policy_regular:  'GSIS-Policy Reg',
      palda_capital_share:  'PAL-DA Capital',
      palda_coopbank_share: 'PAL-DA CoopBank',
      bfar_coop_additional: "BFAR Coop Addt'l",
      palda_regular:        'PAL-DA Regular'
    };

    const activeDeds = [];
    Object.entries(labelMap).forEach(([key, label]) => {
      if (Number(data[key] || 0) > 0) activeDeds.push({ label, value: fmt(data[key]) });
    });
    other_deductions.forEach(d => activeDeds.push({ label: d.name, value: fmt(d.amount) }));
  %>

  <!-- Main Table -->
  <table class="main-table">
    <thead>
      <tr>
        <th style="width:22%;">GROSS EARNINGS</th>
        <th style="width:46%;">DEDUCTIONS</th>
        <th style="width:32%;">PERIODS</th>
      </tr>
    </thead>
    <tbody>
      <tr>

        <!-- GROSS EARNINGS -->
        <td class="col">
          <table class="inner" style="table-layout:fixed;">
            <colgroup><col style="width:55%"><col style="width:45%"></colgroup>
            <tr>
              <td>Monthly Salary</td>
              <td class="r"><%= fmt(data.monthly_salary) %></td>
            </tr>
            <tr>
              <td>PERA</td>
              <td class="r">2,000.00</td>
            </tr>
          </table>
        </td>

        <!-- DEDUCTIONS: single column, label left / amount right -->
        <td class="col">
          <table class="inner" style="table-layout:fixed;">
            <colgroup><col style="width:65%"><col style="width:35%"></colgroup>
            <% activeDeds.forEach(d => { %>
            <tr>
              <td><%= d.label %></td>
              <td class="r"><%= d.value %></td>
            </tr>
            <% }); %>
            <% if (activeDeds.length === 0) { %>
            <tr><td colspan="2" style="color:#aaa; font-style:italic; padding:4px 6px;">No deductions entered</td></tr>
            <% } %>
          </table>
        </td>

        <!-- PERIODS -->
        <td class="col">
          <table class="inner" style="table-layout:fixed;">
            <colgroup><col style="width:50%"><col style="width:50%"></colgroup>
            <tr>
              <td class="b">1ST PERIOD</td>
              <td class="r"><%= fmt(data.first_period) %></td>
            </tr>
            <tr>
              <td class="b">2ND PERIOD</td>
              <td class="r"><%= fmt(data.second_period) %></td>
            </tr>
          </table>
        </td>

      </tr>

      <!-- Totals Footer Row — matches screenshot: GROSS PAY | TOTAL DED | TOTAL NET PAY -->
      <tr class="tfoot">
        <td>GROSS PAY <span style="float:right;"><%= fmt(total_gross) %></span></td>
        <td>TOTAL DEDUCTIONS <span style="float:right;"><%= fmt(total_deductions) %></span></td>
        <td>TOTAL NET PAY <span style="float:right;"><%= fmt(net_pay) %></span></td>
      </tr>

    </tbody>
  </table>

</div>
<script nonce="<%= nonce %>">
    document.getElementById('saveBtn').addEventListener('click', function() {
        document.getElementById('saveForm').submit();
    });
    document.getElementById('printBtn').addEventListener('click', function() { window.print(); });
</script>
</body>
</html>
