<!DOCTYPE html>
<html>
<head>
    <title>My Payslips</title>
</head>
<body>

<h2>My Payslips</h2>

<a href="/dashboard"><button>Back to Dashboard</button></a>

<table border="1" cellpadding="10">
    <tr>
        <th>Month</th>
        <th>Cutoff</th>
        <th>Action</th>
    </tr>

    <% if(payslips.length === 0) { %>
        <tr>
            <td colspan="3">No payslips available</td>
        </tr>
    <% } %>

    <% payslips.forEach(p => { %>
        <tr>
            <td><%= p.month %></td>
            <td><%= p.cutoff %></td>
            <td>
<button class="view-btn" data-id="<%= p.id %>">View</button>
            </td>
        </tr>
    <% }) %>

</table>
<div id="payslipModal" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); justify-content:center; align-items:center;">

    <div style="background:white; padding:20px; width:70%; max-height:80%; overflow:auto; border-radius:10px;">

        <button onclick="closePayslip()" style="float:right;">Close</button>

        <div id="payslipContent">
            Loading payslip...
        </div>

    </div>

</div>
<script nonce="<%= nonce %>">
    document.querySelectorAll('.view-btn').forEach(btn => {
        btn.addEventListener('click', () => openPayslip(btn.dataset.id));
    });
    function openPayslip(id) {
        fetch('/payslip/' + id)
            .then(res => res.text())
            .then(html => {
                document.getElementById('payslipContent').innerHTML = html;
                document.getElementById('payslipModal').style.display = 'flex';
            });
    }
    function closePayslip() {
        document.getElementById('payslipModal').style.display = 'none';
    }
    document.getElementById('closeBtn').addEventListener('click', closePayslip);
    window.addEventListener('click', e => {
        if (e.target === document.getElementById('payslipModal')) closePayslip();
    });
</script>
</body>
</html>